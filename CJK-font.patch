From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: WorkBuddy <workbuddy@local>
Date: Sun, 14 Jun 2026 22:22:00 +0800
Subject: [PATCH] Add CJK font support for Android subtitles

1. Change default font from Roboto-Regular.ttf (Latin only) to
   NotoSansCJK-Regular.ttc (Latin + CJK), so Chinese characters
   display correctly instead of empty boxes.

2. Add hardcoded CJK font fallback candidates in fonts/android.c
   covering AOSP, Xiaomi MIUI, Huawei HarmonyOS, and OPPO ColorOS.

diff --git a/modules/text_renderer/freetype/platform_fonts.h b/modules/text_renderer/freetype/platform_fonts.h
index 1111111..2222222 100644
--- a/modules/text_renderer/freetype/platform_fonts.h
+++ b/modules/text_renderer/freetype/platform_fonts.h
@@ -68,10 +68,10 @@ extern "C" {
 #elif defined( __ANDROID__ )
 # define SYSTEM_FONT_PATH                   "/system/fonts"
-# define SYSTEM_DEFAULT_FONT_FILE           "Roboto-Regular.ttf"
+# define SYSTEM_DEFAULT_FONT_FILE           "NotoSansCJK-Regular.ttc"
 # define SYSTEM_DEFAULT_FAMILY              "sans-serif"
-# define SYSTEM_DEFAULT_MONOSPACE_FONT_FILE "DroidSansMono.ttf"
+# define SYSTEM_DEFAULT_MONOSPACE_FONT_FILE "NotoSansCJK-Regular.ttc"
 # define SYSTEM_DEFAULT_MONOSPACE_FAMILY    "Monospace"
 # define HAVE_GET_FONT_BY_FAMILY_NAME
 #else
diff --git a/modules/text_renderer/freetype/fonts/android.c b/modules/text_renderer/freetype/fonts/android.c
index 3333333..4444444 100644
--- a/modules/text_renderer/freetype/fonts/android.c
+++ b/modules/text_renderer/freetype/fonts/android.c
@@ -352,6 +352,38 @@ int Android_Prepare( vlc_font_select_t *fs )
             return VLC_ENOMEM;
     }

+    {
+        static const char *const cjk_font_candidates[] = {
+            "NotoSansCJK-Regular.ttc",
+            "NotoSansSC-Regular.otf",
+            "NotoSansTC-Regular.otf",
+            "MiSans-Regular.ttf",
+            "HarmonyOS_Sans_SC_Regular.ttf",
+            "OPPOSans-Regular.ttf",
+            NULL
+        };
+
+        for( int i = 0; cjk_font_candidates[i] != NULL; i++ )
+        {
+            char *psz_fontfile;
+            if( asprintf( &psz_fontfile, "%s/%s",
+                          SYSTEM_FONT_PATH, cjk_font_candidates[i] ) < 0 )
+                continue;
+
+            vlc_family_t *p_family =
+                NewFamily( fs, cjk_font_candidates[i],
+                           NULL, &fs->fallback_map, FB_LIST_DEFAULT );
+            if( p_family )
+            {
+                if( !NewFont( psz_fontfile, 0, 0, p_family ) )
+                    free( psz_fontfile );
+            }
+            else
+                free( psz_fontfile );
+        }
+    }
+
     return VLC_SUCCESS;
 }
